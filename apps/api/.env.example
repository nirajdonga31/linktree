# Firebase Admin SDK (same project as frontend)
# Get this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Paste the entire JSON content here as a single line, or save to file and reference path
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id",...}

# Or use separate env vars:
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server Port
PORT=3001
