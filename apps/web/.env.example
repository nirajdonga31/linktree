# ============================================
# Web Frontend Environment Configuration
# ============================================

# Firebase Client Configuration (Public - safe to expose)
# Get this from: Firebase Console → Project Settings → General → Your apps → Config
# Format: JSON string with apiKey, authDomain, projectId, storageBucket, messagingSenderId, appId, measurementId
NEXT_PUBLIC_FIREBASE_CONFIG=

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001
